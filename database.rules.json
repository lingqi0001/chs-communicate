{
  "rules": {
    ".read": false,
    ".write": false,
    
    "users": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth.uid == $uid || root.child('users').child(auth.uid).child('role').val() == 'admin'"
      }
    },
    
    "user_private": {
      "$uid": {
        ".read": "auth.uid == $uid",
        ".write": "auth.uid == $uid"
      }
    },
    
    "messages": {
      "$chatId": {
        ".read": "auth != null && $chatId.contains(auth.uid)",
        ".write": "auth != null && $chatId.contains(auth.uid)",
        "$msgId": {
          ".validate": "(!data.exists() || data.child('senderId').val() == auth.uid) && (newData.child('timestamp').val() <= now)"
        }
      }
    },
    
    "user_chats": {
      "$uid": {
        ".read": "auth.uid == $uid",
        ".write": "auth != null"
      }
    },
    
    "news": {
      ".read": "auth != null",
      "school": {
        ".write": "root.child('users').child(auth.uid).child('role').val() == 'admin' || root.child('users').child(auth.uid).child('role').val() == 'teacher'"
      },
      "club": {
        ".write": "root.child('users').child(auth.uid).child('role').val() == 'admin' || root.child('users').child(auth.uid).child('role').val() == 'teacher'"
      }
    },
    
    "modules": {
      ".read": "auth != null",
      "$module": {
        "$postId": {
          ".write": "auth != null && (!data.exists() || data.child('authorId').val() == auth.uid || root.child('users').child(auth.uid).child('role').val() == 'admin')",
          "likes": {
             ".write": "auth != null"
          },
          "comments": {
             ".write": "auth != null"
          }
        }
      }
    },
    
    "cafeteria": {
      ".read": "auth != null",
      ".write": "root.child('users').child(auth.uid).child('role').val() == 'admin' || root.child('users').child(auth.uid).child('role').val() == 'teacher'"
    },
    
    "eagle_time": {
      ".read": "auth != null",
      "sessions": {
        ".write": "root.child('users').child(auth.uid).child('role').val() == 'admin' || root.child('users').child(auth.uid).child('role').val() == 'teacher'"
      },
      "registrations": {
        "$sessionId": {
          "$uid": {
            ".write": "auth.uid == $uid"
          }
        }
      }
    }
  }
}
