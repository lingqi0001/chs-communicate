{
  "rules": {
    ".read": "auth != null",
    "users": {
      "$uid": {
        ".write": "auth != null"
      }
    },
    "user_private": {
      "$uid": {
        ".write": "auth != null"
      }
    },
    "user_chats": {
      "$uid": {
        ".write": "auth != null"
      }
    },
    "messages": {
      "$chatId": {
        ".write": "auth != null"
      }
    },
    "news": {
      ".write": "auth.token.email.matches(/.*@hcpss.org$/) || auth.token.email == 'moss104088@gmail.com'"
    },
    "modules": {
      "$module": {
        "$postId": {
          ".write": "auth != null",
          "likes": {
            "$uid": {
              ".write": "auth.uid === $uid"
            }
          },
          "comments": {
            "$commentId": {
              ".write": "auth != null"
            }
          },
          "supportVotes": {
            "$uid": {
              ".write": "auth.uid === $uid"
            }
          },
          "notSupportVotes": {
            "$uid": {
              ".write": "auth.uid === $uid"
            }
          }
        }
      }
    },
    "eagle_time": {
      ".write": "auth != null"
    },
    "config": {
      "openai_key": {
        ".read": "auth != null",
        ".write": "auth.token.email == 'moss104088@gmail.com'"
      }
    }
  }
}
