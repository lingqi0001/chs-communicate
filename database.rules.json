{
  "rules": {
    ".read": "auth != null",

    "user_image_index": {
      "ir_v7": {
        ".read": "auth != null",
        ".write": "auth.token.email == 'moss104088@gmail.com'",
        "progress": { "$uid": { ".write": "auth != null && (auth.uid === $uid || auth.token.email.replace('@gmail.com','').replace('@hcpss.org','').replace('@inst.hcpss.org','').replace('.','_') === $uid)" } },
        "links": { "$uid": { ".write": "auth != null && (auth.uid === $uid || auth.token.email.replace('@gmail.com','').replace('@hcpss.org','').replace('@inst.hcpss.org','').replace('.','_') === $uid)" } },
        "matrix": { "$uid": { ".write": "auth != null && (auth.uid === $uid || auth.token.email.replace('@gmail.com','').replace('@hcpss.org','').replace('@inst.hcpss.org','').replace('.','_') === $uid)" } },
        "meta": { "$uid": { ".write": "auth != null && (auth.uid === $uid || auth.token.email.replace('@gmail.com','').replace('@hcpss.org','').replace('@inst.hcpss.org','').replace('.','_') === $uid)" } },
        "canvas": { "$uid": { ".write": "auth != null && (auth.uid === $uid || auth.token.email.replace('@gmail.com','').replace('@hcpss.org','').replace('@inst.hcpss.org','').replace('.','_') === $uid)" } },
        "comments": { "$uid": { ".write": "auth != null && (auth.uid === $uid || auth.token.email.replace('@gmail.com','').replace('@hcpss.org','').replace('@inst.hcpss.org','').replace('.','_') === $uid)" } },
        "notifications": { "$uid": { ".write": "auth != null" } },
        "taskfeedback": { ".write": "auth != null" },
        "duties": { ".write": "auth.token.email == 'moss104088@gmail.com'" },
        "deadlines": { ".write": "auth.token.email == 'moss104088@gmail.com'" },
        "broadcast": { ".write": "auth.token.email == 'moss104088@gmail.com'" }
      },
      ".read": "auth != null",
      "$uid": {
         ".write": "auth != null && auth.uid === $uid"
      }
    },

    "users": {
      ".read": "auth != null",
      "$userId": { ".write": "auth != null" }
    },
    "messages": {
      "$chatId": {
        ".read": "auth != null && ($chatId.contains(auth.uid.toLowerCase()) || $chatId.contains(auth.token.email.replace('@gmail.com','').replace('@hcpss.org','').replace('@inst.hcpss.org','').replace('.','_')) || $chatId.contains('group_'))", 
        ".write": "auth != null",
        "$msgId": { ".write": "auth.token.email == 'moss104088@gmail.com' || !data.exists()" }
      }
    },
    "user_chats": { 
      "$uid": { 
        ".read": "auth != null && (auth.uid.toLowerCase() === $uid.toLowerCase() || auth.token.email.replace('@gmail.com','').replace('@hcpss.org','').replace('@inst.hcpss.org','').replace('.','_') === $uid.toLowerCase() || auth.token.email == 'moss104088@gmail.com')", 
        ".write": "auth != null" 
      } 
    },
    "user_private": { "$uid": { ".read": "auth != null", ".write": "auth != null" } },

    "classes": {
      ".read": "auth != null",
      ".write": "auth != null && (auth.token.email == 'moss104088@gmail.com' || auth.token.email.endsWith('@hcpss.org'))"
    },

    "news": {
      ".read": "auth != null",
      ".write": "auth.token.email == 'moss104088@gmail.com' || auth.token.email.endsWith('@hcpss.org')"
    },

    "modules": {
      "$module": {
        "$postId": {
          ".write": "auth != null",
          "likes": { "$uid": { ".write": "auth.uid === $uid" } },
          "comments": { "$commentId": { ".write": "auth != null" } }
        }
      }
    },
    "user_notifications": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && (auth.uid === $uid || auth.token.email.replace('@gmail.com','').replace('@hcpss.org','').replace('@inst.hcpss.org','').replace('.','_') === $uid)"
      }
    },

    "settings": { 
      ".read": "auth != null", 
      ".write": "auth.token.email == 'moss104088@gmail.com' || auth.token.email.endsWith('@hcpss.org')" 
    },
    "config": {
      ".read": "auth != null",
      ".write": "auth.token.email == 'moss104088@gmail.com'"
    },
    "extension_requests": {
      ".read": "auth.token.email == 'moss104088@gmail.com'",
      ".write": "auth != null"
    },
    "cafeteria": { ".read": "auth != null", ".write": "auth.token.email == 'moss104088@gmail.com'" },
    "eagle_time": { ".read": "auth != null", ".write": "auth != null" }
  }
}
