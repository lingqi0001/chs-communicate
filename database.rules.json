{
  "rules": {
    // 允许所有人读取数据，确保基础访问正常
    ".read": true,

    // 全局设置：仅限管理员账号修改
    "settings": {
      ".write": "auth.token.email == 'moss104088@gmail.com'"
    },

    "news": {
      // 允许所有人写入 news (你可以根据需要收紧为 auth != null)
      ".write": true
    },

    "messages": {
      "$chatId": {
        // 只有登录用户可以写入消息
        ".write": "auth != null"
      }
    },

    "users": {
      "$uid": {
        // 只有登录用户可以操作自己的用户节点
        ".write": "auth != null"
      }
    },

    "user_private": {
      "$uid": {
        // 私有数据保护
        ".write": "auth != null"
      }
    },

    "user_chats": {
      "$uid": {
        // 聊天列表同步
        ".write": "auth != null"
      }
    },

    "classes": {
      // 允许所有登录用户读取班级信息
      ".read": "auth != null",
      // 仅限管理员和教职员工创建或修改班级
      ".write": "auth != null && (auth.token.email == 'moss104088@gmail.com' || auth.token.email.endsWith('@hcpss.org'))"
    },

    "cafeteria": {
      // 允许所有登录用户读取菜单，但仅限管理员和教职员工修改
      ".read": "auth != null",
      ".write": "auth != null && (auth.token.email == 'moss104088@gmail.com' || auth.token.email.endsWith('@hcpss.org'))"
    },

    "modules": {
      "$module": {
        "$postId": {
          ".write": "auth != null",
          "likes": {
            "$uid": {
              ".write": "auth.uid === $uid"
            }
          },
          "comments": {
            "$commentId": {
              ".write": "auth != null"
            }
          },
          "supportVotes": {
            "$uid": {
              ".write": "auth.uid === $uid"
            }
          },
          "notSupportVotes": {
            "$uid": {
              ".write": "auth.uid === $uid"
            }
          }
        }
      }
    },

    "eagle_time": {
      ".write": "auth != null"
    },

    "config": {
      "openai_key": {
        ".read": "auth != null",
        ".write": "auth.token.email == 'moss104088@gmail.com'"
      }
    }
  }
}
